    "modules-left": ["wlr/workspaces", "custom/workspaceright", "custom/workspaceleft", "custom/minusworkspace", "custom/addworkspace", "custom/media", "custom/wofi", "custom/supergraphics", "wlr/window"],
    "modules-center": [],
